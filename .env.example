# Upstream proxy settings
UPSTREAM_SCHEME=http
UPSTREAM_HOST=proxy.example.com
UP_USER=foo
UP_PASS=bar
UPSTREAM_LIST_FILE=
UPSTREAM_LIST=
UPSTREAM_CONNECT_RETRIES=3

# Fixed password for all frontend users
AUTH_PASSWORD=change-me

# Upstream port range
PORT_FIRST=10001
PORT_LAST=10100

# Routing mode: shared | exclusive | shared_capped
MODE=shared
# Hash salt for shared/exclusive
SALT=change-me

# Exclusive fallback: deny | shared
EXCLUSIVE_FALLBACK=deny
# Binding TTL in seconds (0 = permanent)
TTL_SECONDS=0

# shared_capped: max users per port
CAP_PER_PORT=2

# Redis connection
REDIS_HOST=redis
REDIS_PORT=6379

# Note:
# In .env files, use the real credential characters directly.
# Example: if your shell command used 3Ge\~abc, write 3Ge~abc here.
# For line-based imports, place one upstream per line in ./config/upstreams.txt
# and set UPSTREAM_LIST_FILE=/opt/config/upstreams.txt
# For direct text imports, pass a newline-separated UPSTREAM_LIST from shell/CI.
# For 1000+ upstreams, prefer UPSTREAM_LIST_FILE over inline env text.
