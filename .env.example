# Bootstrap environment variables only.
# These two values are read directly at process startup.
# All other runtime settings are stored in the SQLite admin state database.

# SQLite state database
STATE_DB_PATH=./data/proxypool.sqlite3

# Web admin bootstrap port
WEB_PORT=8077

# Startup note:
# - Only the two bootstrap variables above are read directly from environment.
# - Runtime config and proxy list ownership live in the SQLite admin state file.
# - On first boot, open Web Admin and complete /setup to create the admin password.
# - AUTH_PASSWORD and SALT are generated automatically on first boot and can be changed in Web Admin.
